# Estado de runtime do harness no projeto ALVO (criado pelas skills ao trabalhar num
# projeto consumidor). No repo-fonte do PelizzAI ele nao deve existir.
pelizzai/data/.cadence-state.json

# Artefatos efemeros gerados pelo harness no projeto ALVO (tudo vive DENTRO de pelizzai/):
# despacho (task-brief / review-package / pelizzai-handoff), mockups do visual companion
# e relatorios HTML da pelizzai-improving-architecture.
pelizzai/data/handoffs/
pelizzai/data/mockups/
pelizzai/data/reports/

# Logs de debug de editores/agentes
.cursor/debug-*.log

# Relatorios de trabalho gerados na raiz durante manutencao do harness (reposcans,
# auditorias, dossies). Sao insumo de sessao, nunca conteudo do harness: podem citar
# projetos consumidores privados e este repositorio e publico.
/pelizzai-reposcan-*.md
/pelizzai-auditoria-*.md
/*-relatorio.md

# Lixo de SO
Thumbs.db
.DS_Store
